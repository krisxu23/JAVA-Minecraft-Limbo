# Copy to .env and fill in. Never commit real secrets.

PORT=25565
FILE_PATH=./world
UUID=

# Argo / Cloudflare tunnel
DISABLE_ARGO=false
ARGO_PORT=8001
ARGO_DOMAIN=
ARGO_AUTH=

# Optional proxy ports
S5_PORT=
HY2_PORT=
TUIC_PORT=
REALITY_PORT=
REALITY_PRIVATE_KEY=
REALITY_SHORT_ID=

CFIP=www.wto.org
CFPORT=443
NAME=

# Optional integrity pins for native libraries
SBX_LIB_SHA256=
BOT_LIB_SHA256=
